PORT=5000
MONGO_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/orchardlink?retryWrites=true&w=majority
JWT_SECRET=change-me-long-random-string

# Cloudinary (use either short names or CLOUDINARY_* variants — see config/cloudinary.js)
CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Optional: upload timeout ms (default 180000)
# CLOUDINARY_UPLOAD_TIMEOUT_MS=300000

# Optional: restrict browser origins (comma-separated). If unset, CORS reflects any Origin (fine for many apps).
# CLIENT_ORIGINS=https://your-app.vercel.app,https://www.yourdomain.com
